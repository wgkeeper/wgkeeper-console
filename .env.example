# Generate once: openssl rand -hex 32
SECRET_KEY=

# Initial admin password used on first launch.
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Default SQLite database.
# PostgreSQL example: postgres://user:password@postgres:5432/wgkeeper_console
DATABASE_URL=file:/app/data/wgkeeper-console.db

# App port inside the container.
PORT=8000

# Set to false only when serving over plain HTTP.
COOKIE_SECURE=true

# Enable Swagger UI at /docs/index.html
# DOCS=false

# Enable debug logging
# DEBUG=false
